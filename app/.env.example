# EPC API — get-energy-performance-data.communities.gov.uk
# Register at: https://get-energy-performance-data.communities.gov.uk
EPC_API_TOKEN=your_bearer_token_here

# Google Solar API — requires billing-enabled project
# Console: https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=your_api_key_here

# Land Registry SPARQL — no auth required (public endpoint)
# LAND_REGISTRY_SPARQL_ENDPOINT=https://landregistry.data.gov.uk/landregistry/query
